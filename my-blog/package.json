    "db:push:dev": "node scripts/prisma-env.mjs .env.development.local db push",
    "db:push:prod": "node scripts/prisma-env.mjs .env.production.local db push",
    "db:check:local": "node scripts/db-status.mjs .env.local",
    "db:check:dev": "node scripts/db-status.mjs .env.development.local",
    "db:check:prod": "node scripts/db-status.mjs .env.production.local",
    "db:admin:local": "node scripts/admin-sync.mjs .env.local",
    "db:admin:dev": "node scripts/admin-sync.mjs .env.development.local",
    "db:admin:prod": "node scripts/admin-sync.mjs .env.production.local"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.0",
